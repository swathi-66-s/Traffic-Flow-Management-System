import pandas as pd
import matplotlib.pyplot as plt

# Load data
df = pd.read_csv('../data/traffic_data.csv')

# Convert hour
df['hour'] = pd.to_datetime(df['time']).dt.hour

# Show data
print(df.head())

# Group data
traffic_by_hour = df.groupby('hour')['vehicle_count'].mean()

# Bar chart
plt.figure()
traffic_by_hour.plot(kind='bar')
plt.title("Average Traffic by Hour")
plt.xlabel("Hour")
plt.ylabel("Vehicle Count")
plt.savefig('../images/peak_hours.png')
plt.show()

# Line chart
plt.figure()
plt.plot(df['hour'], df['vehicle_count'])
plt.title("Traffic Trend")
plt.xlabel("Hour")
plt.ylabel("Vehicle Count")
plt.savefig('../images/traffic_trend.png')
plt.show()

# Peak hour
print("Peak Hour:", traffic_by_hour.idxmax())